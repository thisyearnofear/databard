# ElevenLabs API Key (REQUIRED)
# Free tier: Web UI only, no API access
# Starter ($5/mo): Full API access to all premade voices (RECOMMENDED)
# Get your key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_key_here

# Browser Automation Provider (EXPERIMENTAL - for free tier fallback)
# Options: auto (default), agent-browser, browser-use-cli, browser-use, tinyfish
# - auto: Automatically detects and uses the first available provider
# - agent-browser: Local Rust CLI (requires: npm install -g agent-browser)
# - browser-use-cli: Local Python CLI (requires: curl -fsSL https://browser-use.com/cli/install.sh | bash)
# - browser-use: Cloud API (requires: BROWSER_USE_API_KEY)
# - tinyfish: Cloud AI agent (requires: TINYFISH_API_KEY)
# Note: Browser automation requires ElevenLabs web UI login and is slower than API
BROWSER_PROVIDER=auto

# Cloud Provider API Keys (optional, only needed if using cloud providers)
# BROWSER_USE_API_KEY=your_browser_use_key
# TINYFISH_API_KEY=sk-tinyfish-your_key

# Optional: LLM for natural podcast scripts (falls back to templates if not set)
# Works with any OpenAI-compatible API (OpenAI, Anthropic via proxy, Ollama, etc.)
# OPENAI_API_KEY=your_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Optional: Protect synthesis endpoints from unauthorized use
# If not set, endpoints are open (fine for local dev)
# DATABARD_API_SECRET=your_secret_here

# Optional: Stripe for Pro subscriptions
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID=price_...

# Optional: Token-gated private RSS feed
# DATABARD_FEED_TOKEN=your_team_token

# Optional: Webhook URL for notifications on episode generation (Slack, Discord, etc.)
# DATABARD_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# Optional: Configure default data source (openmetadata, dbt-cloud, dbt-local)
# These can be overridden in the UI
# OPENMETADATA_URL=http://localhost:8585
# OPENMETADATA_TOKEN=your_token_here
# Optional: Shared OpenMetadata sandbox mode (used when UI selects "Use Sandbox")
# OM_SANDBOX_URL=https://sandbox.open-metadata.org
# OM_SANDBOX_TOKEN=your_sandbox_bot_jwt
# NEXT_PUBLIC_OM_SANDBOX_URL=https://sandbox.open-metadata.org
# DBT_CLOUD_ACCOUNT_ID=12345
# DBT_CLOUD_PROJECT_ID=67890
# DBT_CLOUD_TOKEN=your_token_here
# DBT_MANIFEST_PATH=./target/manifest.json

# Optional: Solana configuration (for on-chain episode minting and Palm USD payments)
# NEXT_PUBLIC_SOLANA_NETWORK=devnet  # mainnet-beta, devnet, or testnet
# NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com  # Custom RPC endpoint
# NEXT_PUBLIC_PALM_USD_MINT=PUSDxMnNvSoANp7B7A3DJ1Ao23DRvuxxu7KF7uN2oNrh  # Palm USD token mint
# PALM_USD_RECIPIENT=your_treasury_wallet  # Where Palm USD payments are received

# Optional: Initia (secondary chain for on-chain minting)
# NEXT_PUBLIC_INITIA_CHAIN_ID=initiation-2
# DATABARD_CONTRACT_ADDRESS=your_contract_address
# INITIA_REST_URL=https://rest.testnet.initia.xyz
