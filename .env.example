ELEVENLABS_API_KEY=your_key_here

# Optional: LLM for natural podcast scripts (falls back to templates if not set)
# Works with any OpenAI-compatible API (OpenAI, Anthropic via proxy, Ollama, etc.)
# OPENAI_API_KEY=your_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Optional: Configure default data source (openmetadata, dbt-cloud, dbt-local)
# These can be overridden in the UI
# OPENMETADATA_URL=http://localhost:8585
# OPENMETADATA_TOKEN=your_token_here
# DBT_CLOUD_ACCOUNT_ID=12345
# DBT_CLOUD_PROJECT_ID=67890
# DBT_CLOUD_TOKEN=your_token_here
# DBT_MANIFEST_PATH=./target/manifest.json
